# Contoh environment untuk biometric-sync
# Simpan salinan real di: /etc/biometric-sync.env
# Jangan commit file berisi secret ke repo

ERP_TOKEN="your_api_key:your_api_secret"

# Ops flags opsional
# ZK_SKIP_PING=1        # jika ICMP diblok
# ZK_DISABLE_ON_FETCH=0 # kontrol disable/enable_device di fetch